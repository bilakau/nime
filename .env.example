# ==========================================
# MaouAnime / KuzenAnime — Environment Vars
# Copy this file ke `.env` lalu isi dengan nilai asli.
# JANGAN commit `.env` ke git.
# ==========================================

# Port server Express (default: 3000)
PORT=3000

# Secret untuk sign JWT — pakai string acak yang panjang & sulit ditebak.
# Contoh generate: `openssl rand -hex 64`
JWT_SECRET=ganti-dengan-secret-acak-yang-panjang

# ==========================================
# SUPABASE
# Project Settings → API di dashboard Supabase
# https://supabase.com/dashboard/project/<project-id>/settings/api
# ==========================================

# URL project Supabase
SUPABASE_URL=https://your-project-id.supabase.co

# Anon (public) key — boleh dipakai di frontend, dibatasi oleh Row Level Security.
SUPABASE_KEY=your-anon-public-key

# Service Role key — DIREKOMENDASIKAN untuk backend.
# Bypass RLS, jangan pernah expose ke browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Project ID Supabase (opsional, untuk referensi)
SUPABASE_PROJECT_ID=your-project-id
